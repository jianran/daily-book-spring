# DeepSeek AI API Key - Get yours at https://deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Discord Configuration (for sending essay to DM)
# Option 1: Webhook URL (easiest)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Option 2: Direct DM via Bot (requires bot setup)
# DISCORD_USER_ID=your-user-id-here
# DISCORD_BOT_TOKEN=your-bot-token-here

# Google Books API Key - Get yours at https://console.cloud.google.com/apis/credentials
GOOGLE_BOOKS_API_KEY=your-google-books-api-key-here

# Optional: Override these in application.properties or as environment variables
# SPRING_PROFILES_ACTIVE=production
# SERVER_PORT=8080
